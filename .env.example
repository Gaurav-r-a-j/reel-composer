# Reel Composer – optional env config (no secrets in repo)
# Copy to .env or .env.local and fill in. .env is gitignored by default in Vite projects.

# Google Gemini API key (get one at https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=

# Optional: default model (e.g. gemini-2.5-flash or gemini-2.5-pro)
# VITE_GEMINI_DEFAULT_MODEL=gemini-2.5-flash
